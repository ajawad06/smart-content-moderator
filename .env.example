# Root environment for docker-compose. Copy to .env and adjust.
# These override the defaults baked into docker-compose.yml.

# Auth (use a long random string in real deployments)
JWT_SECRET=dev-only-change-me-please-32chars
JWT_EXPIRES_IN=7d

# CORS: comma-separated origins, or * for any
CORS_ORIGIN=*

# AI moderation: "mock" needs no key; "claude" calls the Anthropic API
MODERATION_PROVIDER=mock
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# Seed admin (created on startup if it doesn't exist). Change before any real deployment.
ADMIN_EMAIL=admin@acm.local
ADMIN_PASSWORD=admin12345
