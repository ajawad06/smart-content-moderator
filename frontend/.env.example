# Frontend config.

# Local dev only: target the Vite dev-server proxy uses to reach the backend.
# In docker-compose this is set to http://backend:4000.
VITE_PROXY_TARGET=http://localhost:4000

# Split deploy only (Vercel + Render): absolute backend API base URL.
# Leave UNSET for local dev and Docker (the app falls back to the proxied "/api").
# Example: https://acm-backend.onrender.com/api
# VITE_API_URL=
