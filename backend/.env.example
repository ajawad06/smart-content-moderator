# Backend environment configuration
NODE_ENV=development
PORT=4000

# MongoDB connection string.
# Local dev (mongo running on host): mongodb://localhost:27017/acm
# Docker compose (service name "mongo"): mongodb://mongo:27017/acm
MONGO_URI=mongodb://localhost:27017/acm

# Auth
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d

# Comma-separated allowed origins, or * for any
CORS_ORIGIN=*

# AI moderation provider: "mock" (no key required) or "claude" (calls Anthropic API)
MODERATION_PROVIDER=mock
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# Seed admin (created on startup if it doesn't exist). Change before any real deployment.
ADMIN_EMAIL=admin@acm.local
ADMIN_PASSWORD=admin12345
